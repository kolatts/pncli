{
  "name": "@kolatts/pncli",
  "version": "1.3.0",
  "description": "The Paperwork Nightmare CLI — One command does what three meetings couldn't.",
  "type": "module",
  "bin": {
    "pncli": "./dist/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.5.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "eslint": "^9.25.1",
    "husky": "^9.1.7",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "keywords": [
    "cli",
    "jira",
    "bitbucket",
    "developer-tools",
    "code-review",
    "agent",
    "automation"
  ],
  "license": "Apache-2.0",
  "files": [
    "dist",
    "LICENSE",
    "NOTICE",
    "README.md",
    "copilot-instructions.md"
  ]
}
