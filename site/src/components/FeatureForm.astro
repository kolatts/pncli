---
const endpoint        = import.meta.env.PUBLIC_FEEDBACK_ENDPOINT      ?? '';
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '0x4AAAAAAC8hdd6wCVRVf8YH';
---

{turnstileSiteKey && (
  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
)}

<form
  id="feedback-form"
  class="flex flex-col gap-5"
  novalidate
>
  <!-- Kind -->
  <fieldset class="flex gap-4">
    <legend class="text-sm font-semibold text-ink mb-2 w-full">Type</legend>
    <label class="flex items-center gap-2 cursor-pointer">
      <input
        type="radio"
        name="kind"
        value="bug"
        required
        class="accent-coral w-4 h-4"
      />
      <span class="text-sm text-ink">Bug report</span>
    </label>
    <label class="flex items-center gap-2 cursor-pointer">
      <input
        type="radio"
        name="kind"
        value="feature"
        class="accent-violet w-4 h-4"
      />
      <span class="text-sm text-ink">Feature request</span>
    </label>
  </fieldset>

  <!-- Title -->
  <div class="flex flex-col gap-1.5">
    <label for="fb-title" class="text-sm font-semibold text-ink">
      Title <span class="text-coral" aria-hidden="true">*</span>
    </label>
    <input
      id="fb-title"
      name="title"
      type="text"
      required
      maxlength="120"
      placeholder="Short summary (max 120 chars)"
      class="w-full rounded-lg border border-ink/20 bg-cream px-4 py-2.5 text-sm text-ink placeholder:text-ink/30 focus:outline-none focus:ring-2 focus:ring-violet/40 focus:border-violet/60 transition-all"
    />
  </div>

  <!-- Body -->
  <div class="flex flex-col gap-1.5">
    <label for="fb-body" class="text-sm font-semibold text-ink">
      Details <span class="text-coral" aria-hidden="true">*</span>
    </label>
    <textarea
      id="fb-body"
      name="body"
      required
      rows="5"
      placeholder="Steps to reproduce, expected vs actual behaviour, or your feature idea…"
      class="w-full rounded-lg border border-ink/20 bg-cream px-4 py-2.5 text-sm text-ink placeholder:text-ink/30 focus:outline-none focus:ring-2 focus:ring-violet/40 focus:border-violet/60 transition-all resize-y"
    ></textarea>
  </div>

  <!-- Email -->
  <div class="flex flex-col gap-1.5">
    <label for="fb-email" class="text-sm font-semibold text-ink">
      Email <span class="text-coral" aria-hidden="true">*</span>
    </label>
    <input
      id="fb-email"
      name="email"
      type="email"
      required
      maxlength="254"
      placeholder="you@example.com"
      class="w-full rounded-lg border border-ink/20 bg-cream px-4 py-2.5 text-sm text-ink placeholder:text-ink/30 focus:outline-none focus:ring-2 focus:ring-violet/40 focus:border-violet/60 transition-all"
    />
    <p class="text-xs text-ink/50">Used to confirm receipt and notify you when your issue is resolved. Not shared publicly.</p>
  </div>

  <!-- Rate limit note -->
  <p class="text-xs text-ink/40">One submission per day per IP address. Issues are reviewed and filed within a minute of receipt.</p>

  <!-- Service (optional) -->
  <div class="flex flex-col gap-1.5">
    <label for="fb-service" class="text-sm font-semibold text-ink">
      Service <span class="text-ink/30 font-normal">(optional)</span>
    </label>
    <select
      id="fb-service"
      name="service"
      class="w-full rounded-lg border border-ink/20 bg-cream px-4 py-2.5 text-sm text-ink focus:outline-none focus:ring-2 focus:ring-violet/40 focus:border-violet/60 transition-all"
    >
      <option value="">— select if applicable —</option>
      <option>Git</option>
      <option>Jira</option>
      <option>Bitbucket</option>
      <option>Confluence</option>
      <option>SonarQube</option>
      <option>SDElements</option>
      <option>Azure DevOps</option>
      <option>Other</option>
    </select>
  </div>

  <!-- Turnstile CAPTCHA (rendered only when site key is configured) -->
  {turnstileSiteKey && (
    <div class="cf-turnstile" data-sitekey={turnstileSiteKey}></div>
  )}

  <!-- Honeypot (hidden from real users) -->
  <input
    type="text"
    name="hp"
    tabindex="-1"
    autocomplete="off"
    class="sr-only"
    aria-hidden="true"
  />

  <!-- Hidden: version from ?version= query param, populated by script -->
  <input type="hidden" name="version" id="fb-version" value="" />

  <!-- Status region -->
  <div
    id="fb-status"
    role="status"
    aria-live="polite"
    class="min-h-[1.5rem] text-sm"
  ></div>

  <!-- Submit -->
  <button
    type="submit"
    class="self-start inline-flex items-center gap-2 bg-coral text-cream font-semibold px-6 py-3 rounded-lg hover:opacity-90 disabled:opacity-50 disabled:cursor-not-allowed transition-opacity"
  >
    Submit
  </button>
</form>

<script define:vars={{ endpoint }}>
  const LS_EMAIL_KEY = 'pncli_feedback_email';

  // Populate version from ?version= query param
  const params = new URLSearchParams(window.location.search);
  const versionInput = document.getElementById('fb-version');
  if (versionInput && params.get('version')) {
    versionInput.value = params.get('version');
  }

  // Pre-fill email from localStorage
  const emailInput = document.getElementById('fb-email');
  if (emailInput) {
    const saved = localStorage.getItem(LS_EMAIL_KEY);
    if (saved) emailInput.value = saved;
  }

  const form = document.getElementById('feedback-form');
  const status = document.getElementById('fb-status');
  const submit = form.querySelector('[type="submit"]');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    status.textContent = '';
    submit.disabled = true;
    submit.textContent = 'Submitting…';

    const data = Object.fromEntries(new FormData(form));

    try {
      const res = await fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const json = await res.json().catch(() => ({}));

      if (json.ok) {
        // Persist email for next visit before resetting the form
        const email = form.querySelector('#fb-email')?.value;
        if (email) localStorage.setItem(LS_EMAIL_KEY, email);

        status.innerHTML =
          `<span class="text-violet font-medium">${json.message ?? 'Thanks! Your feedback has been received.'}</span>`;
        form.reset();
        // Restore email after reset so it stays filled
        if (email && emailInput) emailInput.value = email;
      } else {
        status.innerHTML =
          `<span class="text-coral">${json.error ?? 'Something went wrong. Please try again.'}</span>`;
      }
    } catch {
      status.innerHTML =
        `<span class="text-coral">Network error — please check your connection and try again.</span>`;
    } finally {
      submit.disabled = false;
      submit.textContent = 'Submit';
    }
  });
</script>
