---
const command = 'npm install -g @kolatts/pncli';
---

<section id="install" class="w-full bg-cream py-16 px-6">
  <div class="max-w-2xl mx-auto">
    <h2 class="font-display text-2xl font-bold text-ink text-center mb-8">
      Get started in seconds
    </h2>

    <div class="rounded-xl overflow-hidden border border-ink/10 shadow-lg shadow-ink/5">
      <div class="bg-ink/5 border-b border-ink/10 px-5 py-2.5 flex items-center gap-1.5">
        <span class="w-3 h-3 rounded-full bg-ink/10"></span>
        <span class="w-3 h-3 rounded-full bg-ink/10"></span>
        <span class="w-3 h-3 rounded-full bg-ink/10"></span>
        <span class="font-mono text-xs text-ink/30 ml-2">terminal</span>
      </div>
      <div class="bg-ink px-6 py-5 flex items-center justify-between gap-4">
        <code class="font-mono text-sm md:text-base text-cream/90 select-all">{command}</code>
        <button
          id="copy-btn"
          class="shrink-0 text-cream/30 hover:text-cream/80 transition-colors"
          aria-label="Copy install command"
          type="button"
        >
          <svg id="icon-copy" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
          <svg id="icon-check" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden text-coral"><polyline points="20 6 9 17 4 12"/></svg>
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  const btn = document.getElementById('copy-btn')!;
  const iconCopy  = document.getElementById('icon-copy')!;
  const iconCheck = document.getElementById('icon-check')!;

  btn.addEventListener('click', () => {
    navigator.clipboard.writeText('npm install -g @kolatts/pncli').catch(() => {});
    iconCopy.classList.add('hidden');
    iconCheck.classList.remove('hidden');
    setTimeout(() => {
      iconCopy.classList.remove('hidden');
      iconCheck.classList.add('hidden');
    }, 2000);
  });
</script>
