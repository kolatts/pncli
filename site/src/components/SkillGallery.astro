---
import { getCollection } from 'astro:content';
import SkillCard from './SkillCard.astro';

const entries = await getCollection('skills');

// Stable display order
const order = [
  'review-pull-request',
  'address-pr-feedback',
  'create-bug-from-pr-finding',
  'check-build-status',
  'pre-merge-quality-check',
  'review-vulnerabilities',
  'vulnerability-triage-to-tickets',
  'dependency-cve-remediation',
  'threat-model-to-backlog',
  'tech-debt-to-backlog',
  'license-audit-to-tickets',
  'daily-standup-prep',
];

const getOrderIndex = (id: string) => { const i = order.indexOf(id); return i === -1 ? Infinity : i; };
const skills = [...entries].sort((a, b) => getOrderIndex(a.id) - getOrderIndex(b.id));
---

<div class="not-prose grid grid-cols-1 sm:grid-cols-2 gap-4 my-6">
  {skills.map(skill => (
    <SkillCard
      title={skill.data.title}
      description={skill.data.description}
      providers={skill.data.providers ?? 'none'}
      slug={skill.id}
    />
  ))}
</div>
