---
import { getCollection } from 'astro:content';
import SkillCard from './SkillCard.astro';

const entries = await getCollection('skills');

// Stable display order
const order = [
  'review-pull-request',
  'address-pr-feedback',
  'create-bug-from-pr-finding',
  'check-build-status',
  'pre-merge-quality-check',
  'review-vulnerabilities',
  'daily-standup-prep',
];

const skills = [...entries].sort(
  (a, b) => order.indexOf(a.id) - order.indexOf(b.id)
);
---

<div class="not-prose grid grid-cols-1 sm:grid-cols-2 gap-4 my-6">
  {skills.map(skill => (
    <SkillCard
      title={skill.data.title}
      description={skill.data.description}
      providers={skill.data.providers ?? 'none'}
      slug={skill.id}
    />
  ))}
</div>
