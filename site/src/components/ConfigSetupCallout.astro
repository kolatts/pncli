---
const steps = [
  { cmd: 'pncli config init',        label: 'Set up global auth (Jira, Bitbucket, Confluence, …)' },
  { cmd: 'pncli config init --repo', label: 'Add repo-level defaults — commit this to git' },
  { cmd: 'pncli config check',       label: 'Verify all connections are working' },
];
---

<div class="not-prose my-8 rounded-xl overflow-hidden border border-ink/10 shadow-sm">
  <div class="bg-ink/5 border-b border-ink/10 px-5 py-2.5 flex items-center gap-1.5">
    <span class="w-3 h-3 rounded-full bg-ink/10" aria-hidden="true"></span>
    <span class="w-3 h-3 rounded-full bg-ink/10" aria-hidden="true"></span>
    <span class="w-3 h-3 rounded-full bg-ink/10" aria-hidden="true"></span>
    <span class="font-mono text-xs text-ink/30 ml-2">First-time setup</span>
  </div>
  <div class="bg-ink divide-y divide-cream/5">
    {steps.map((step, i) => (
      <div class="px-6 py-4 flex items-start gap-4">
        <span class="shrink-0 font-mono text-xs text-violet/60 w-4 mt-0.5 select-none">{i + 1}</span>
        <div class="flex-1 min-w-0">
          <code class="font-mono text-sm text-cream/90">{step.cmd}</code>
          <p class="text-xs text-cream/35 mt-1">{step.label}</p>
        </div>
        <button
          class="copy-btn shrink-0 text-cream/25 hover:text-cream/70 transition-colors mt-0.5"
          data-cmd={step.cmd}
          aria-label={`Copy: ${step.cmd}`}
          type="button"
        >
          <svg class="icon-copy" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
          <svg class="icon-check hidden" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        </button>
      </div>
    ))}
  </div>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const cmd = btn.dataset.cmd ?? '';
      navigator.clipboard.writeText(cmd).catch(() => {});
      const iconCopy  = btn.querySelector('.icon-copy') as SVGElement;
      const iconCheck = btn.querySelector('.icon-check') as SVGElement;
      iconCopy.classList.add('hidden');
      iconCheck.classList.remove('hidden');
      btn.classList.replace('text-cream/25', 'text-coral');
      setTimeout(() => {
        iconCopy.classList.remove('hidden');
        iconCheck.classList.add('hidden');
        btn.classList.replace('text-coral', 'text-cream/25');
      }, 2000);
    });
  });
</script>
