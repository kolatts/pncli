---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const entries = await getCollection('skills');
  return entries.map(entry => ({
    params: { slug: entry.id },
    props:  { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const providerLabel: Record<string, string> = {
  both:      'Bitbucket · Azure DevOps',
  bitbucket: 'Bitbucket',
  ado:       'Azure DevOps',
  none:      'All repos',
};

const label = providerLabel[entry.data.providers ?? 'none'] ?? 'All repos';

const serviceList = entry.data.services
  ? entry.data.services.split(',').map((s: string) => s.trim()).filter(Boolean)
  : [];
---

<Base
  title={`${entry.data.title} — pncli skill`}
  description={entry.data.description}
>
  <div class="max-w-3xl mx-auto px-6 py-16">
    <a
      href="/pncli/skills/"
      class="inline-flex items-center gap-1.5 text-sm text-ink/40 hover:text-ink transition-colors mb-8"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5"/><path d="m12 5-7 7 7 7"/></svg>
      All skills
    </a>

    <header class="mb-10">
      <p class="font-mono text-xs uppercase tracking-wider text-ink/40 mb-2">Skill</p>
      <h1 class="font-display text-4xl font-bold text-ink mb-3">{entry.data.title}</h1>
      <div class="flex items-center gap-3">
        <p class="text-ink/60 text-lg flex-1">{entry.data.description}</p>
        <span class="font-mono text-xs text-ink/40 bg-ink/5 border border-ink/10 px-2 py-1 rounded shrink-0">
          {label}
        </span>
      </div>
      {serviceList.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mt-3">
          {serviceList.map((svc: string) => (
            <span class="font-mono text-xs text-violet bg-violet/10 border border-violet/20 px-2 py-0.5 rounded">
              {svc}
            </span>
          ))}
        </div>
      )}
    </header>

    <div class="prose prose-neutral max-w-none
      prose-headings:font-display prose-headings:text-ink
      prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
      prose-h3:text-base prose-h3:font-semibold prose-h3:mt-8 prose-h3:mb-3
      prose-p:text-ink/70
      prose-li:text-ink/70 prose-li:text-sm prose-li:leading-relaxed
      prose-strong:text-ink prose-strong:font-semibold
      prose-a:text-coral prose-a:no-underline hover:prose-a:underline
      prose-code:font-mono prose-code:text-sm prose-code:bg-ink/5 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
      prose-pre:bg-ink prose-pre:text-cream prose-pre:rounded-xl">
      <Content />
    </div>

    <div class="mt-12 pt-6 border-t border-ink/10">
      <p class="text-sm text-ink/40 font-mono">
        Source: <a
          href={`https://github.com/kolatts/pncli/blob/main/.claude/skills/${entry.id}/SKILL.md`}
          class="text-coral hover:underline"
          target="_blank"
          rel="noopener"
        >.claude/skills/{entry.id}/SKILL.md</a>
      </p>
    </div>
  </div>
</Base>

<style>
  .prose ol li code,
  .prose ul li code {
    display: block;
    background-color: var(--color-ink);
    color: #e8e3f0;
    padding: 0.4rem 0.75rem;
    border-radius: 0.375rem;
    margin-top: 0.35rem;
    font-size: 0.8125rem;
    line-height: 1.6;
  }
</style>
