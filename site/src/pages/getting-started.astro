---
import { getEntry, render } from 'astro:content';
import Base from '../layouts/Base.astro';

const entry = await getEntry('docs', 'getting-started');
if (!entry) throw new Error('docs/getting-started entry not found — did the prebuild script run?');
const { Content } = await render(entry);
---

<Base title="Getting Started — pncli" description={entry.data.description}>
  <div class="max-w-3xl mx-auto px-6 py-16">
    <header class="mb-10">
      <p class="font-mono text-xs uppercase tracking-wider text-ink/40 mb-2">Docs</p>
      <h1 class="font-display text-4xl font-bold text-ink mb-3">Getting Started</h1>
      <p class="text-ink/60">{entry.data.description}</p>
    </header>

    <div class="prose prose-neutral max-w-none
      prose-headings:font-display prose-headings:text-ink
      prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4
      prose-h3:text-lg prose-h3:mt-8 prose-h3:mb-3
      prose-p:text-ink/70
      prose-li:text-ink/70 prose-li:text-sm prose-li:leading-relaxed
      prose-a:text-coral prose-a:no-underline hover:prose-a:underline
      prose-code:font-mono prose-code:text-sm prose-code:bg-ink/5 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
      prose-pre:bg-ink prose-pre:text-cream prose-pre:rounded-xl">
      <Content />
    </div>
  </div>
</Base>

<style>
  /*
   * Style commands inside workflow step lists (ordered lists only).
   * Each <li> has a text label + one or more inline <code> elements that
   * are the actual CLI commands. Display them as block-level terminal rows.
   */
  .prose ol li code {
    display: block;
    background-color: var(--color-ink);
    color: #e8e3f0;
    padding: 0.4rem 0.75rem;
    border-radius: 0.375rem;
    margin-top: 0.35rem;
    font-size: 0.8125rem;
    line-height: 1.6;
  }
</style>
