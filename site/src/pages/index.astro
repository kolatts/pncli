---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import CodeTabs from '../components/CodeTabs.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import monster from '../assets/monster.png';

const latestEntries = (await getCollection('changelog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const fmt = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
---

<Base>
  <Hero />
  <CodeTabs />

  <!-- Why pncli -->
  <section class="w-full py-20 px-6 bg-cream border-t border-ink/5">
    <div class="max-w-5xl mx-auto">
      <div class="flex flex-col md:flex-row items-center gap-10 md:gap-16">
        <!-- Monster -->
        <div class="shrink-0 w-56 md:w-72">
          <Image
            src={monster}
            alt="The paperwork monster — bureaucracy personified"
            class="w-full h-auto"
          />
        </div>

        <!-- Content -->
        <div class="flex-1 min-w-0">
          <h2 class="font-display text-4xl md:text-5xl font-bold text-ink mb-8">
            Cut through the red tape.
          </h2>
          <div class="flex flex-col gap-3">
            <div class="rounded-xl border border-ink/10 bg-ink text-cream p-5">
              <p class="font-display font-semibold text-base mb-1">Three meetings to get one PR merged.</p>
              <p class="text-cream/55 text-sm leading-relaxed">
                Your org blocked MCP. Your agents still need to review PRs, create issues,
                and manage code reviews.
              </p>
            </div>
            <div class="rounded-xl border border-coral/25 bg-coral/5 p-5">
              <p class="font-display font-semibold text-ink text-base mb-1">One command instead.</p>
              <p class="text-ink/55 text-sm leading-relaxed">
                pncli is the shim layer — one npm install and you're cutting through red tape.
              </p>
            </div>
            <div class="rounded-xl border border-violet/25 bg-violet/5 p-5">
              <p class="font-display font-semibold text-ink text-base mb-1">Works with your stack.</p>
              <p class="text-ink/55 text-sm leading-relaxed">
                Jira Data Center, Bitbucket Server, Confluence, SonarQube, SDElements,
                and Azure DevOps. All from the terminal.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ServiceGrid />

  <!-- For AI agents -->
  <section class="w-full py-20 px-6 bg-ink text-cream">
    <div class="max-w-5xl mx-auto">
      <div class="mb-10">
        <p class="text-violet font-mono text-sm mb-3 tracking-wide">agent-first</p>
        <h2 class="font-display text-4xl md:text-5xl font-bold">
          Built for AI agents.
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-3">
        <div class="flex gap-4 p-5 rounded-xl border border-cream/10 hover:border-cream/20 hover:bg-cream/5 transition-all">
          <span class="shrink-0 font-mono text-violet text-sm w-7 mt-0.5" aria-hidden="true">{"{}"}</span>
          <p class="font-mono text-sm text-cream/65 leading-relaxed">
            Every command returns structured JSON to stdout
          </p>
        </div>
        <div class="flex gap-4 p-5 rounded-xl border border-cream/10 hover:border-cream/20 hover:bg-cream/5 transition-all">
          <span class="shrink-0 font-mono text-violet text-sm w-7 mt-0.5" aria-hidden="true">ok</span>
          <p class="font-mono text-sm text-cream/65 leading-relaxed">
            Errors are JSON too — always check <code class="text-coral">ok</code>
          </p>
        </div>
        <div class="flex gap-4 p-5 rounded-xl border border-cream/10 hover:border-cream/20 hover:bg-cream/5 transition-all">
          <span class="shrink-0 font-mono text-violet text-sm w-7 mt-0.5" aria-hidden="true">▷</span>
          <p class="font-mono text-sm text-cream/65 leading-relaxed">
            <code class="text-coral">--dry-run</code> lets agents preview before executing
          </p>
        </div>
        <div class="flex gap-4 p-5 rounded-xl border border-cream/10 hover:border-cream/20 hover:bg-cream/5 transition-all">
          <span class="shrink-0 font-mono text-violet text-sm w-7 mt-0.5" aria-hidden="true">⚙</span>
          <p class="font-mono text-sm text-cream/65 leading-relaxed">
            See <code class="text-coral">copilot-instructions.md</code> for workflow patterns
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Changelog teaser — live from CHANGELOG.md -->
  <section class="w-full py-20 px-6 bg-cream border-t border-ink/5">
    <div class="max-w-5xl mx-auto">
      <div class="flex items-baseline justify-between mb-10 gap-4 flex-wrap">
        <h2 class="font-display text-4xl font-bold text-ink">What's new.</h2>
        <a href="/pncli/changelog/" class="text-sm font-medium text-coral hover:underline">
          View full changelog →
        </a>
      </div>
      <div class="grid md:grid-cols-3 gap-4">
        {latestEntries.map(entry => (
          <a
            href={`/pncli/changelog/${entry.data.version}/`}
            class="group rounded-xl border border-ink/10 bg-cream p-6 hover:border-ink/20 hover:shadow-sm transition-all"
          >
            <div class="flex items-center gap-2 mb-3">
              <span class="font-mono text-xs font-semibold bg-coral text-cream px-2.5 py-1 rounded-full">
                v{entry.data.version}
              </span>
              <span class="text-xs text-ink/40">{fmt.format(entry.data.date)}</span>
            </div>
            <p class="text-sm text-ink/70 leading-relaxed group-hover:text-ink transition-colors">
              {entry.data.summary}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
