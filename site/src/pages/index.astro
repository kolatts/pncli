---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import hero from '../assets/hero.png';
---

<Base>
  <section class="max-w-5xl mx-auto px-6 py-20 flex flex-col items-center text-center gap-8">
    <h1 class="font-display text-4xl md:text-6xl font-bold text-ink leading-tight">
      One command does what<br />three meetings couldn't.
    </h1>
    <p class="text-lg text-ink/70 max-w-xl">
      pncli gives AI coding agents and humans structured CLI access to Jira, Bitbucket,
      Confluence, SonarQube, and more. Site coming soon — full launch shortly.
    </p>
    <a
      href="https://github.com/kolatts/pncli"
      class="inline-flex items-center gap-2 bg-coral text-cream font-semibold px-6 py-3 rounded-lg hover:opacity-90 transition-opacity"
    >
      View on GitHub
    </a>
    <Image
      src={hero}
      alt="pncli hero illustration"
      class="w-full max-w-2xl rounded-2xl shadow-xl mt-4"
    />
  </section>
</Base>
