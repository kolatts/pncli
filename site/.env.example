# URL of the Azure Function feedback endpoint.
# Set this as a repo variable (PUBLIC_FEEDBACK_ENDPOINT) in GitHub Actions
# and it will be injected at build time via pages-deploy.yml.
# For local dev, copy this file to .env and fill in the value.
PUBLIC_FEEDBACK_ENDPOINT=https://pncli-prod-feedback.azurewebsites.net/api/submit

# Cloudflare Turnstile site key for CAPTCHA protection on the feedback form.
# Get a free key at https://dash.cloudflare.com/?to=/:account/turnstile
# For local dev use the always-pass test key: 1x00000000000000000000AA
# The production key is baked in as the default; override here for local dev if needed.
PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAC8hdd6wCVRVf8YH
