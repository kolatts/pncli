# Normalize line endings to LF on commit
* text=auto eol=lf

# Source
*.ts    text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf

# Config / data
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.toml  text eol=lf
*.env   text eol=lf

# Docs / text
*.md    text eol=lf
*.txt   text eol=lf

# Shell scripts always LF
*.sh    text eol=lf

# Binaries — do not touch
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.gz    binary
*.zip   binary
*.tgz   binary
